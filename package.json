{
  "name": "@khimaros/pi-evolve",
  "version": "0.2.0",
  "description": "self-modifying hook extension for pi-coding-agent -- implements the hook protocol so opencode-evolve hooks run in pi unchanged",
  "keywords": [
    "pi-package"
  ],
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khimaros/pi-evolve.git"
  },
  "homepage": "https://github.com/khimaros/pi-evolve#readme",
  "bugs": {
    "url": "https://github.com/khimaros/pi-evolve/issues"
  },
  "type": "module",
  "main": "src/extension/index.ts",
  "pi": {
    "extensions": [
      "src/extension/index.ts"
    ]
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc",
    "test": "python3 ./tests/pi_integration_test.py"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.6",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  },
  "allowScripts": {
    "@google/genai@1.52.0": true,
    "protobufjs@7.6.4": true,
    "protobufjs@7.5.9": true
  }
}
